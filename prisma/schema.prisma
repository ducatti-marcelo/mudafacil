generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(cuid())
  name                     String?
  email                    String    @unique
  emailVerified            DateTime?
  image                    String?
  stripeCustomerId         String?
  stripePriceId            String?
  stripeSubscriptionId     String?
  stripeCurrentPeriodEnd   DateTime?
  trialEndsAt              DateTime?
  plan                     Plan      @default(FREE)

  accounts                 Account[]
  sessions                 Session[]
  mudancas                 Mudanca[]

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Plan {
  FREE
  TRIAL
  PRO
}

// Entidades do MudaFácil

model Item {
  id            String   @id @default(cuid())
  nome          String
  categoria     String
  iconeUrl      String
  larguraCm     Float
  alturaCm      Float
  profundidadeCm Float
  pesoKg        Float
  volumeM3      Float

  mudancas      Mudanca[] @relation("MudancaItens")
  posicoes      CargaLayoutItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Caminhao {
  id            String   @id @default(cuid())
  nome          String
  tipo          String
  capacidadeM3  Float
  capacidadeKg  Float
  comprimentoCm Float
  larguraCm     Float
  alturaCm      Float
  imagemUrl     String

  mudancas      Mudanca[]
  layouts       CargaLayout[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Transportadora {
  id              String    @id @default(cuid())
  nome            String
  logoUrl         String
  notaMedia       Float     @default(0)
  totalAvaliacoes Int       @default(0)
  cidade          String
  tiposCaminhao   String[]

  cotacoes        Cotacao[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Mudanca {
  id              String    @id @default(cuid())
  userId          String
  enderecoOrigem  String
  enderecoDestino String
  dataDesejada    DateTime?
  status          StatusMudanca @default(ORCAMENTO)
  caminhaoId      String?

  user            User      @relation(fields: [userId], references: [id])
  caminhao        Caminhao? @relation(fields: [caminhaoId], references: [id])
  itens           Item[]    @relation("MudancaItens")
  cotacoes        Cotacao[]
  layout          CargaLayout?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Cotacao {
  id               String    @id @default(cuid())
  mudancaId        String
  transportadoraId String
  precoCentavos    Int
  dataDisponivel   DateTime
  seguroIncluso    Boolean   @default(false)
  validade         DateTime

  mudanca          Mudanca   @relation(fields: [mudancaId], references: [id])
  transportadora   Transportadora @relation(fields: [transportadoraId], references: [id])

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model CargaLayout {
  id                String    @id @default(cuid())
  mudancaId         String    @unique
  caminhaoId        String
  ocupacaoPercentual Float    @default(0)

  mudanca           Mudanca   @relation(fields: [mudancaId], references: [id])
  caminhao          Caminhao  @relation(fields: [caminhaoId], references: [id])
  itensPosicionados CargaLayoutItem[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model CargaLayoutItem {
  id          String   @id @default(cuid())
  layoutId    String
  itemId      String
  x           Float
  y           Float
  rotacao     Float    @default(0)

  layout      CargaLayout @relation(fields: [layoutId], references: [id])
  item        Item     @relation(fields: [itemId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum StatusMudanca {
  ORCAMENTO
  AGUARDANDO_APROVACAO
  APROVADA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}